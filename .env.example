# App URL (canonical production URL for OAuth redirects)
NEXT_PUBLIC_APP_URL=https://www.bayitbeseder.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Green API (WhatsApp) - shared instance with Kami
# CRITICAL: Do NOT set webhookUrl on this instance!
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=

# WhatsApp webhook signature secret (HMAC-SHA256, hex-encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WHATSAPP_WEBHOOK_SECRET=

# WhatsApp phone numbers (comma-separated, Israeli format: 05x-xxx-xxxx)
WHATSAPP_PHONES=

# Upstash Redis (distributed rate limiting — required on Vercel)
# Create a free database at https://console.upstash.com/ → Redis → REST API
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# Cron job secret (Vercel Cron authorization)
CRON_SECRET=

# Web Push VAPID keys
# Generate fresh keys with:
#   node -e "const wp = require('./node_modules/web-push'); const k = wp.generateVAPIDKeys(); console.log(k)"
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is used in both the browser (subscription) and server (sending)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@bayitbeseder.com

# Sentry error monitoring (https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
